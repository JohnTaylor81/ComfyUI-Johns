et":{"name":"temporal_size"},"link":null},{"label":"Temporal Overlap","localized_name":"temporal_overlap","name":"temporal_overlap","type":"INT","widget":{"name":"temporal_overlap"},"link":null}],"outputs":[{"label":"Latent","localized_name":"LATENT","name":"LATENT","type":"LATENT","links":[43]}],"properties":{"Node name for S&R":"VAEEncodeTiled"},"widgets_values":[1024,64,64,8],"color":"#222","bgcolor":"#000"},{"id":1,"type":"UNETLoader","pos":[0,30],"size":[400,82],"flags":{},"order":7,"mode":0,"inputs":[{"label":"Model","localized_name":"unet_name","name":"unet_name","type":"COMBO","widget":{"name":"unet_name"},"link":null},{"label":"Weight DType","localized_name":"weight_dtype","name":"weight_dtype","type":"COMBO","widget":{"name":"weight_dtype"},"link":null}],"outputs":[{"localized_name":"MODEL","name":"MODEL","type":"MODEL","links":[3]}],"properties":{"Node name for S&R":"UNETLoader"},"widgets_values":["Flux.1 D\\FLUX.1 Dev.safetensors","default"],"color":"#322","bgcolor":"#533"},{"id":32,"type":"MarkdownNote","pos":[-430,30],"size":[400,940],"flags":{},"order":8,"mode":0,"inputs":[],"outputs":[],"properties":{},"widgets_values":["## Usage\n\nLoad Your **Image** and **Models**\n\nIn the **LoRA Loader**, **enable** and set up Your **LoRA**s if any (first number column is **Model Strenght**, second is **Clip**). Tip: **Click** the **Arrow** buttons for **fine** adjustments, **CTRL** + **Click** for **bigger** steps. Click the **Number** to **Reset**.\n\nUse the **Prompt Library** to load Your **preset** or write **Prompt** and **Negative** prompt\n\nAdjust **Guider**, **Sampler**, **Scheduler**\n\nIf You **don't** want to upscale the **Image**, use the **Set Mode** nodes to **bypass** both **Upscale Image (using Model)** and **Upscale Image** nodes.\n\nIf Your **Upscale Model** is let's say **4x** but You only want **2x**, You can Resize **after** Upscaling: Make sure **both** Upscale Image (using Model) and Upscale Image nodes set to **Enabled**. Set the **Resolution Calulator**'s **Multiplier** to **2** which will take the **Input Image Dimensions**, multiplies it by **2** and passes it to the Upscale Image **Width** and **Height** parammeters.\n\nFinally, set the self-explanatory parameters of the **Tiled Sampler** and **run** the **Workflow**.\n\n---\n\n## Important!\n\nDo **NOT** use **Mute** on Upscaler / Resizer! Enable or Bypass only.\n\n---\n\nThe **Multiplier** is applied to the **original** Input Image dimensions. With **Multiplier** set to **2**, You'll double the original image size regardless of what Upscale Model You're using if Resizer is enabled. When the Resizer is Bypassed, the Multiplier does nothing.\n\n---\n\n## Dependency\n\nThis workflow uses **RMBG** to remove background, and since **RMBG**'s segmenter is **broken** (for me at least), **SAM3** is also required. Install those first. Alternatively, You can create and use Your own Mask(s).\n\n---\n\n## Color Codes\n\n### Red Nodes\n\nNormally **Loaders** and things You **need** to change for Your specific setup **before** First Use\n\n---\n\n### Purple Nodes\n\nThings You probably **will** interact with the most\n\n---\n\n### Blue Nodes\n\nGenerally just **stet it and forget it** nodes that You'll set once\n\n---\n\n### Black Nodes\nYou don't ever really need to touch those\n"],"color":"#432","bgcolor":"#653"},{"id":5,"type":"JohnsSetModeConnected","pos":[0,1020],"size":[400,60],"flags":{},"order":16,"mode":0,"inputs":[{"localized_name":"AnyInput","name":"AnyInput","type":"*","link":1},{"label":"Upscaler","localized_name":"Mode","name":"Mode","type":"STRING","widget":{"name":"Mode"},"link":null}],"outputs":[{"localized_name":"Passthrough","name":"Passthrough","type":"*","links":[]}],"properties":{"Node name for S&R":"JohnsSetModeConnected"},"widgets_values":["Upscale Image (using Model): Enabled"],"color":"#2a363b","bgcolor":"#3f5159"},{"id":6,"type":"JohnsSetModeConnected","pos":[0,1140],"size":[400,60],"flags":{},"order":20,"mode":0,"inputs":[{"loca